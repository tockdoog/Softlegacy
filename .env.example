# Ruta del archivo: .env.example
# Plantilla de variables de entorno de SoftLegacy.
#
# CÓMO USAR ESTE ARCHIVO:
# 1) En tu proyecto local: crea un archivo llamado ".env.local" (con el punto
#    al inicio, sin ".txt") y complétalo ahí con tus claves reales.
# 2) En Vercel: NO subas ".env.local" a tu repositorio. Ve a tu proyecto en
#    vercel.com > Settings > Environment Variables, y agrega ahí las mismas
#    claves y valores, marcando Production, Preview y Development.
# NUNCA subas un archivo con claves reales a GitHub.

# Clave de API de Resend (https://resend.com) — crea una cuenta gratuita y
# genera tu clave en el panel "API Keys".
RESEND_API_KEY=API_Resend

# Correo donde recibirás los mensajes del formulario de contacto.
# Es obligatorio: sin esta variable, el endpoint rechaza el envío.
CONTACT_TO_EMAIL=softlegacytkd@gmail.com


# Remitente del correo. Mientras no tengas un dominio propio verificado en
# Resend, usa el valor de prueba "onboarding@resend.dev" (solo permite
# enviar hacia el correo con el que creaste tu cuenta de Resend). Cuando
# tengas un dominio verificado (ej. softlegacy.com.co), cámbialo por algo
# como "contacto@softlegacy.com.co".
CONTACT_FROM_EMAIL=onboarding@resend.dev

# URL completa de tu sitio en producción (ej. https://softlegacy.com.co).
# Se usa para validar que las solicitudes al formulario vengan de tu propio
# dominio y no de otro sitio (protección anti-CSRF). Déjala vacía en
# desarrollo local si prefieres no aplicar esta validación mientras pruebas.
NEXT_PUBLIC_SITE_URL=https://softlegacy.vercel.app